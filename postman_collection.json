{
  "info": {
    "name": "Flask Celery Task API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Producer - Create Item",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"item\": \"book\"\n}"
        },
        "url": {
          "raw": "http://localhost:5000/produce",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["produce"]
        }
      }
    },
    {
      "name": "Check Status",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:5000/status",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["status"]
        }
      }
    },
    {
      "name": "Concurrent Requests",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:5000/concurrent-requests?delay_value=2",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["concurrent-requests"],
          "query": [
            {
              "key": "delay_value",
              "value": "2"
            }
          ]
        }
      }
    },
    {
      "name": "Clear All Items",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "http://localhost:5000/clear",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5000",
          "path": ["clear"]
        }
      }
    }
  ]
}